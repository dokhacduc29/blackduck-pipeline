# =====================================================================
# .env.example — Template biến môi trường cho AI Trend Agent
# =====================================================================
# SAO CHÉP file này thành .env rồi điền giá trị thật.
# KHÔNG commit file .env lên git (đã có trong .gitignore).
# =====================================================================

# --- NEWS SOURCES ---
NEWS_API_KEY=your_newsapi_key_here           # https://newsapi.org → My Account → API Key

REDDIT_CLIENT_ID=your_reddit_client_id      # https://www.reddit.com/prefs/apps → "script" app
REDDIT_CLIENT_SECRET=your_reddit_secret     # Client secret của app Reddit

# --- AI (GEMINI) ---
GEMINI_API_KEY=your_gemini_api_key_here     # https://aistudio.google.com/app/apikey

# --- DATABASE (SUPABASE) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# --- TELEGRAM (PHASE 6) ---
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # BotFather → /newbot
TELEGRAM_CHAT_ID=your_chat_id_or_channel_id                    # @userinfobot để lấy ID

# --- PIPELINE TUNING (tùy chọn) ---
TOPIC=artificial intelligence               # Từ khóa mặc định nếu không truyền qua CLI
STARTUP_DELAY_SECONDS=0                     # Delay khởi động (dùng trong Docker/K8s readiness)
